# ── Model Configuration ─────────────────────────────────
MODEL_NAME=bert-base-multilingual-cased
MODEL_PATH=models/sentiment_classifier
MAX_SEQ_LENGTH=256
BATCH_SIZE=32
NUM_LABELS=3
LABELS=negative,neutral,positive

# ── Training Hyperparameters ────────────────────────────
LEARNING_RATE=2e-5
EPOCHS=3
WARMUP_STEPS=500
WEIGHT_DECAY=0.01
MAX_GRAD_NORM=1.0

# ── API Configuration ───────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
RATE_LIMIT_PER_MINUTE=60

# ── UI Configuration ────────────────────────────────────
UI_HOST=0.0.0.0
UI_PORT=8501

# ── Language Configuration ──────────────────────────────
SUPPORTED_LANGUAGES=en,es,fr,de,pt
LANGUAGE_CONFIDENCE_THRESHOLD=0.8

# ── Logging ──────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=logs/sentiment_analyzer.log

# ── Paths ───────────────────────────────────────────────
DATA_RAW_DIR=data/raw
DATA_PROCESSED_DIR=data/processed
DATASET_FILE=combined_dataset.csv
REPORTS_DIR=reports
